# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Only the UDM_* values need editing for a typical setup. The .env file holds
# your gateway password, so it is gitignored — never commit it.

# --- UniFi Dream Machine Pro --------------------------------------------------
# Controller URL of your gateway. Usually its LAN IP over HTTPS.
UDM_URL=https://192.168.1.1
# A LOCAL UniFi OS account (not your Ubiquiti cloud/SSO login). A read-only
# "Viewer" role restricted to local access is enough. See the README.
UDM_USERNAME=monitor
UDM_PASSWORD=change-me
# Network site name; "default" for virtually all home setups.
UDM_SITE=default
# The UDM uses a self-signed certificate, so verification is skipped by default.
UDM_INSECURE=true
# Per-scrape timeout.
UDM_TIMEOUT=10s

# --- Grafana ------------------------------------------------------------------
# Password for the built-in "admin" user (used only if you log in to edit).
GRAFANA_ADMIN_PASSWORD=admin
# Anonymous viewing + hidden login form make the stack land straight on the
# dashboard with zero clicks and allow sharing via a link. Set both to false
# if you ever expose Grafana beyond your trusted LAN.
GRAFANA_ANON_ENABLED=true
GRAFANA_DISABLE_LOGIN=true

# --- AI root-cause analysis (optional) ---------------------------------------
# When a latency/loss event fires, a Claude agent investigates it (querying
# Prometheus, running fresh traceroute/DNS, attributing hops via RDAP) and writes
# a plain-language root cause onto the dashboard as a numbered annotation.
#
# Leave this BLANK to disable AI diagnostics entirely — everything else still
# works. Setting it sends event telemetry (traceroute hops/IPs, ISP info) to the
# Anthropic API and incurs per-event API cost. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
# Optional: route the AI at a local, Anthropic-compatible model server (e.g. an
# LLM proxy on your LAN) instead of the hosted API. With this set, investigations
# cost nothing per request and no ANTHROPIC_API_KEY is required. Leave BLANK to
# use the hosted Anthropic API.
ANTHROPIC_BASE_URL=

# --- Dashboard "take a look" button (optional) -------------------------------
# The dashboard has a button that triggers an on-demand AI investigation. It is
# rate-limited in config/targets.yml (diagnostics.manual) because each click runs
# an LLM call + active probes and the dashboard allows anonymous viewing. The
# request is proxied server-side through Grafana, so the prober port stays
# internal. The button needs two Grafana plugins, installed automatically via the
# default below; override only if you mirror plugins or want to pin versions.
# GRAFANA_INSTALL_PLUGINS=volkovlabs-form-panel,yesoreyeram-infinity-datasource
