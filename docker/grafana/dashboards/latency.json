          "confirm": false,
          "payload": {
            "refId": "A",
            "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "justrebootit-prober" },
            "type": "json",
            "source": "url",
            "parser": "backend",
            "format": "table",
            "root_selector": "",
            "url": "http://prober:9430/api/underload",
            "url_options": { "method": "POST", "body_type": "raw", "body_content_type": "application/json" }
          }
        },
        "elements": [
          {
            "id": "host",
            "uid": "host",
