{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
        "enable": true,
        "expr": "increase(diagnostic_triggered_total[$__rate_interval]) > 0",
        "iconColor": "red",
        "name": "Diagnostics fired",
        "step": "60s",
        "tagKeys": "target,reason",
        "titleFormat": "diagnostic: {{reason}}",
        "textFormat": "{{target}}"
      },
      {
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "iconColor": "purple",
        "name": "AI diagnosis",
        "target": { "type": "tags", "matchAny": false, "tags": ["ai-diagnosis"], "limit": 100 }
      }
    ]
  },
  "description": "Home internet latency, packet loss and network-path health, correlated with UniFi Dream Machine Pro WAN throughput and gateway load. Built to be shared with an ISP network engineer.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["justrebootit", "latency", "network"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
        "definition": "label_values(probe_loss_ratio, target)",
        "includeAll": false,
        "label": "Target (detail panels)",
        "multi": false,
        "name": "target",
        "options": [],
        "query": { "qryType": 1, "query": "label_values(probe_loss_ratio, target)", "refId": "target" },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Home Internet Latency",
  "uid": "justrebootit-home-latency",
  "version": 1,
  "weekStart": "",
  "panels": [
    {
      "type": "row",
      "id": 1,
      "title": "Overview — is it bad right now?",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Worst packet loss (any target)",
      "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
          "expr": "max(probe_loss_ratio)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "id": 3,
      "title": "WAN latency (gateway)",
      "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 40 },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
          "expr": "udm_wan_latency_ms",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "id": 4,
      "title": "WAN download",
      "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "bps", "decimals": 1 },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
          "expr": "udm_wan_rx_bytes_per_second * 8",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "id": 5,
      "title": "WAN upload",
      "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "bps", "decimals": 1 },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
          "expr": "udm_wan_tx_bytes_per_second * 8",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "id": 6,
      "title": "Gateway CPU",
      "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
          "expr": "udm_gateway_cpu_percent",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "id": 7,
      "title": "Gateway memory",
      "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 92 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
          "expr": "udm_gateway_memory_percent",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 8,
      "title": "Median latency — all targets",
      "description": "Median round-trip time to every probed target. Spikes shared across all targets point upstream (ISP/WAN); a spike on one target points to that path.",
      "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 5 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 0,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
          "expr": "probe_rtt_median_seconds",
          "legendFormat": "{{target}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 9,
      "title": "Packet loss — all targets",
      "description": "Fraction of pings lost per cycle. Loss to your gateway means a problem inside the house; loss to upstream anchors but not the gateway points to the ISP.",
      "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 5 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 60,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
          "expr": "probe_loss_ratio",
          "legendFormat": "{{target}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "id": 20,
      "title": "Smoke & path detail — $target",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }
    },
    {
      "type": "timeseries",
      "id": 21,
      "title": "Latency distribution (\"smoke\") — $target",
      "description": "Smokeping-style view: the shaded band is the spread between the best and worst ping in each cycle (jitter); the inner band is the 10th–90th percentile; the bold line is the median. A wide band means jittery latency even if the median looks fine.",
      "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 0,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "worst" },
            "properties": [
              { "id": "custom.fillBelowTo", "value": "best" },
              { "id": "custom.lineWidth", "value": 0 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "rgba(115,150,255,0.25)" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "p90" },
            "properties": [
              { "id": "custom.fillBelowTo", "value": "p10" },
              { "id": "custom.lineWidth", "value": 0 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "rgba(80,110,255,0.45)" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "median" },
            "properties": [
              { "id": "custom.lineWidth", "value": 2 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "dark-blue" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
          "expr": "probe_rtt_best_seconds{target=\"$target\"}",
          "legendFormat": "best",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
          "expr": "probe_rtt_percentile_seconds{target=\"$target\", percentile=\"10\"}",
          "legendFormat": "p10",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
          "expr": "probe_rtt_median_seconds{target=\"$target\"}",
          "legendFormat": "median",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
          "expr": "probe_rtt_percentile_seconds{target=\"$target\", percentile=\"90\"}",
          "legendFormat": "p90",
          "refId": "D"
        },
        {
          "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
          "expr": "probe_rtt_worst_seconds{target=\"$target\"}",
          "legendFormat": "worst",
          "refId": "E"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 22,
      "title": "Per-hop latency (traceroute) — $target",
      "description": "Round-trip time to each router on the path, by hop number (TTL). Watch which hop is the first to spike: that segment owns the problem. Hover a hop to see the router address.",
      "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 25 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 5,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
          "expr": "traceroute_hop_rtt_seconds{target=\"$target\"}",
          "legendFormat": "hop {{ttl}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "id": 30,
      "title": "UniFi Dream Machine — WAN & gateway load",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 }
    },
    {
      "type": "timeseries",
      "id": 31,
      "title": "WAN throughput",
      "description": "Live WAN download/upload rate. Compare against the latency panels above: latency spikes that line up with throughput maxing out indicate congestion / bufferbloat rather than an ISP fault.",
      "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 20,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
          "expr": "udm_wan_rx_bytes_per_second * 8",
          "legendFormat": "download",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
          "expr": "udm_wan_tx_bytes_per_second * 8",
          "legendFormat": "upload",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 32,
      "title": "Gateway CPU & memory",
      "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
          "expr": "udm_gateway_cpu_percent",
          "legendFormat": "cpu",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
          "expr": "udm_gateway_memory_percent",
          "legendFormat": "memory",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 33,
      "title": "Gateway-reported latency & speedtest ping",
      "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 44 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 0,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
          "expr": "udm_wan_latency_ms",
          "legendFormat": "wan latency",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
          "expr": "udm_speedtest_ping_ms",
          "legendFormat": "speedtest ping",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 34,
      "title": "Connected clients",
      "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 44 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
          "expr": "udm_clients",
          "legendFormat": "clients (lan+wlan)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "id": 40,
      "title": "Path discovery & triggered diagnostics",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 52 }
    },
    {
      "type": "timeseries",
      "id": 41,
      "title": "Active discovered paths",
      "description": "Which candidates path discovery has promoted to active probing (value 1). Discovery keeps a path-diverse subset whose early hops differ, so the active set covers distinct routes rather than redundant ones. The set is re-evaluated every discovery interval.",
      "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 53 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
          "expr": "discovery_selected == 1",
          "legendFormat": "{{target}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 42,
      "title": "Candidate distance (hops to reach)",
      "description": "Hop count to each discovery candidate. Discovery prefers shorter paths because fewer intervening hops means a spike localizes more precisely.",
      "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 53 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 1,
            "fillOpacity": 0,
            "showPoints": "auto",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "asc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
          "expr": "discovery_reach_hops",
          "legendFormat": "{{target}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 43,
      "title": "Diagnostic triggers",
      "description": "When a latency spike or packet loss is detected, a deeper diagnostic run fires (also marked as a red annotation across the dashboard). Bars show how many triggered, by target and reason.",
      "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 61 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 70,
            "showPoints": "never",
            "stacking": { "mode": "normal", "group": "A" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
          "expr": "increase(diagnostic_triggered_total[$__rate_interval])",
          "legendFormat": "{{target}} ({{reason}})",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
