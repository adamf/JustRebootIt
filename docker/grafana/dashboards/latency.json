    {
      "type": "row",
      "id": 40,
      "title": "Path discovery & triggered diagnostics",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 62 }
    },
    {
      "type": "timeseries",
      "id": 41,
      "title": "Active discovered paths",
      "description": "Which candidates path discovery has promoted to active probing (value 1). Discovery keeps a path-diverse subset whose early hops differ, so the active set covers distinct routes rather than redundant ones. The set is re-evaluated every discovery interval.",
      "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 63 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "line",
