    {
      "type": "row",
      "id": 50,
      "title": "Latency under load (bufferbloat) — streaming-stutter probe",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 96 }
    },
    {
      "type": "timeseries",
      "id": 51,
      "title": "Latency: idle vs under load",
      "description": "The bufferbloat probe saturates the link with a controlled transfer while pinging a stable host. 'idle' is the RTT before load, 'loaded' is during it, and 'increase' is the gap between them — the bufferbloat that causes streaming stutter. A large increase (tens to hundreds of ms) means the link buffers under load; the fix is usually SQM/Smart Queues on that end. Empty unless the underload probe is enabled in the config.",
      "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 97 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto",
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*increase.*" },
            "properties": [
              { "id": "custom.fillOpacity", "value": 30 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["last", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
          "expr": "underload_rtt_idle_seconds",
          "legendFormat": "{{target}} {{direction}} idle",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
          "expr": "underload_rtt_loaded_seconds",
          "legendFormat": "{{target}} {{direction}} loaded",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "justrebootit-prometheus" },
          "expr": "underload_rtt_increase_seconds",
          "legendFormat": "{{target}} {{direction}} increase (bufferbloat)",
          "refId": "C"
        }
      ]
    },
